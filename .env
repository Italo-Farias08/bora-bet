# Segredo usado para assinar o cookie de sessão.
# Já veio preenchido com um valor aleatório forte — não precisa trocar,
# mas NUNCA reaproveite esse mesmo valor em outro projeto.
SESSION_SECRET=b04fdcf9086c5c654ecd3355ed84842c60e67863ee5eed3635c099845d14867b

# Token usado para acessar as rotas /api/admin/* (confirmar/rejeitar Pix).
# Guarde esse valor com você — é o que você vai colocar no header
# "x-admin-token" quando for confirmar um pagamento manualmente.
ADMIN_TOKEN=ZinksggZ2

# Deixe como "development" enquanto estiver testando localmente.
# Mude para "production" só quando for publicar o site de verdade
# (isso ativa cookie seguro, que exige HTTPS).
NODE_ENV=development


# Porta em que o servidor vai rodar (opcional, padrão 3000)
PORT=3000